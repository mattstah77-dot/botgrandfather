# Telegram Bot API Base URL
TELEGRAM_BOT_API_URL=https://api.telegram.org

# Webhook Configuration
# For local development: use ngrok (https://your-ngrok-id.ngrok.io)
# For production: use your Render URL (https://your-service.onrender.com)
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook

# Application
NODE_ENV=development
PORT=3000

# Database (local development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram-bot-platform

# Database (Render production - auto-populated)
# DATABASE_URL=postgres://user:password@hostname:port/database?sslmode=require
